# Public production origin for metadata, manifest, sitemap, and robots.
NEXT_PUBLIC_SITE_URL=

# Future analytics wiring toggle.
NEXT_PUBLIC_ENABLE_ANALYTICS=false

# Supabase browser-safe values. Use publishable keys for new projects.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Optional legacy compatibility for older Supabase projects.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only Supabase keys. Never prefix these with NEXT_PUBLIC.
SUPABASE_SECRET_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Stripe values for future checkout session and webhook wiring.
# Vercel Marketplace may provision STRIPE_PUBLISHABLE_KEY; expose the NEXT_PUBLIC
# alias only when a browser payment UI needs it.
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
