# Supabase browser-safe values. Use publishable keys for new projects.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Optional legacy compatibility for older Supabase projects.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only Supabase key. Never prefix this with NEXT_PUBLIC.
SUPABASE_SERVICE_ROLE_KEY=

# Stripe placeholders for future checkout session and webhook wiring.
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
